# --- Database (PostgreSQL) ---
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}?schema=public

# --- Backend (NestJS) ---
PORT=3000
JWT_SECRET=
# Requests per minute per IP (rate limit)
THROTTLE_LIMIT=120

# --- Frontend (Vite) ---
VITE_API_URL=http://localhost:3000
# Set to "false" to call the live backend instead of offline mocks
VITE_OFFLINE_MODE=true
# Optional blockchain config
VITE_CHAIN_NAME=MBG Chain Testnet
VITE_CHAIN_ID=31337
