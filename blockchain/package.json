{
  "name": "mbg-chain-contracts",
  "version": "1.0.0",
  "private": true,
  "description": "Solidity smart contracts for MBG Chain (Makan Bergizi Gratis): permit registry, inter-regional redistribution ledger, and B2B procurement/RFQ with on-chain supplier reputation.",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "node": "hardhat node",
    "deploy:local": "hardhat run scripts/deploy.ts --network localhost",
    "deploy:hardhat": "hardhat run scripts/deploy.ts",
    "deploy:amoy": "hardhat run scripts/deploy.ts --network amoy"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "dotenv": "^17.4.2",
    "hardhat": "^2.22.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4"
  }
}
