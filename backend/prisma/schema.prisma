// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  VENDOR
  KITCHEN
  SCHOOL
  ADMIN
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String
  name         String?
  role         Role     @default(USER)
  
  businessName String?
  phone        String?
  commodities  String?
  latitude     Float?
  longitude    Float?
  address      String?
  status       String?  @default("active")
  rating       Float?   @default(0.0)
  description  String?
  auditScore   Int?
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model School {
  id           String   @id @default(uuid())
  name         String
  latitude     Float
  longitude    Float
  address      String
  capacity     Int
  status       String   @default("active")
  description  String?
  phone        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Kitchen {
  id           String   @id @default(uuid())
  name         String
  latitude     Float
  longitude    Float
  address      String
  capacity     Int
  status       String   @default("active")
  rating       Float    @default(0.0)
  description  String?
  phone        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
